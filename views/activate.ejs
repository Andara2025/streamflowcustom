<% layout('layout') -%>

<div class="flex items-center justify-center min-h-[70vh]">
  <div class="bg-gray-800 rounded-xl p-8 border border-gray-700 shadow-xl max-w-md w-full text-center">
    <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="ti ti-lock-access text-4xl text-primary"></i>
    </div>
    
    <h2 class="text-2xl font-bold text-white mb-2">Fitur Terkunci (Pro Version)</h2>
    <p class="text-gray-400 text-sm mb-8">
      Fitur <b>User Management</b> dan <b>Reporting & Revenue</b> hanya tersedia untuk pemegang Lisensi Pro. Silakan masukkan Serial Number / Lisensi Anda untuk membuka fitur ini.
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/10 border border-red-500/50 text-red-500 text-sm rounded-lg p-3 mb-6 text-left flex items-start gap-2">
        <i class="ti ti-alert-circle mt-0.5"></i>
        <span><%= error %></span>
      </div>
    <% } %>
    
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-500/10 border border-green-500/50 text-green-500 text-sm rounded-lg p-3 mb-6 text-left flex items-start gap-2">
        <i class="ti ti-check mt-0.5"></i>
        <span><%= success %></span>
      </div>
    <% } %>

    <form action="/admin/activate" method="POST" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <div>
        <input type="text" name="license_key" required placeholder="Masukkan Serial Number (misal: PEJUANG-MONET-...)"
          class="w-full bg-dark-700 border border-gray-600 text-white px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-center font-mono uppercase tracking-wider">
      </div>
      
      <button type="submit" class="w-full bg-primary hover:bg-rose-600 text-white font-medium py-3 rounded-lg transition-colors flex items-center justify-center gap-2">
        <i class="ti ti-key"></i>
        <span>Aktivasi Lisensi Pro</span>
      </button>
    </form>
    
    <div class="mt-6 pt-6 border-t border-gray-700">
      <p class="text-xs text-gray-500">
        Belum punya lisensi? Hubungi developer untuk pembelian Lisensi Pro.
      </p>
    </div>
  </div>
</div>
