                  class="w-full bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary [color-scheme:dark]">
                <p class="text-xs text-gray-500 mt-1">Kosongkan jika tidak ada batas waktu.</p>
              </div>
            </div>
          </div>
        </form>
